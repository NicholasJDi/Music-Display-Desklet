{
    "head1": {
        "type": "header",
        "description": "Desklet Settings"
    },
    "x_size": {
        "type": "spinbutton",
        "description": "X Size (pixels)",
        "default": 200,
        "min": 10,
        "max": 400,
        "step": 10,
        "tooltip": "The X Size of the Desklet"
    },
    "y_size": {
        "type": "spinbutton",
        "description": "Y Size (pixels)",
        "default": 200,
        "min": 10,
        "max": 400,
        "step": 10,
        "tooltip": "The size of the Margin around Art"
    },
    "head2": {
        "type": "header",
        "description": "Text Settings"
    },
    "text_enabled":{
        "type": "checkbox",
        "description": "Enabled",
        "default": true
    },
    "text_format": {
        "type": "entry",
        "description": "Format",
        "default": "%time%",
        "tooltip": "%time%, %position%, %length%"
    },
    "text_font": {
        "type": "fontchooser",
        "description": "Choose a font",
        "default": "sans 12"
    },
    "text_position": {
        "type": "combobox",
        "description": "Position",
        "default": "top_right",
        "options": {
            "Top Left": "top_left",
            "Top Right": "top_right",
            "Bottom Left": "bottom_left",
            "Bottom Right": "bottom_right",
            "Center": "center"
        },
        "tooltip": "Text Anchor Position"
    },
    "anchor_text_in_art" : {
        "type": "checkbox",
        "description": "Lock Anchor Within Art",
        "default": true,
        "tooltip": "Text Anchor is based on Art Size, for when Art does not fit Desklet Size properly."
    },
    "head3":{
        "type": "header",
        "description": "Art Settings"
    },
    "art_anchor" : {
        "type": "combobox",
        "description": "Anchor",
        "default": "top_right",
        "options": {
            "Top Left": "top_left",
            "Top Right": "top_right",
            "Bottom Left": "bottom_left",
            "Bottom Right": "bottom_right",
            "Center": "center"
        },
        "tooltip": "Art Anchor Position, for when Art does not fit Desklet Size properly."
    },
    "margin": {
        "type": "spinbutton",
        "description": "Margin Size (pixels)",
        "default": 10,
        "min": 0,
        "max": 200,
        "step": 1,
        "tooltip": "The size of the Margin around Art"
    },
    "margin_color" : {
        "type": "colorchooser",
        "description": "Margin Color",
        "default": "white",
        "tooltip": "The Color of the Margin around Art",
        "dependency": "margin>0"
    },
    "art_dir" : {
        "type": "filechooser",
        "description": "Art Override Directory",
        "default": "",
        "tooltip": "The Directory to fetch Art Overrides from,\nFiles are formmated as \"(Artist) - (Title).png\" so \"Lemmino - Cipher.png\" for example.",
        "select-dir" : true
    },
    "head4": {
        "type": "header",
        "description": "Player Settings"
    },
    "player_poll_interval": {
        "type": "scale",
        "description": "Player polling interval (seconds)",
        "tooltip": "How often the desklet checks for players. (Track Poll Interval is fixed to 1 second, this may be changed)",
        "default": 3,
        "min": 1,
        "max": 10,
        "step": 0.1
        },
        "player_whitelist": {
            "type": "entry",
            "description": "Player whitelist",
            "default": "rhythmbox,spotify",
            "tooltip": "Comma-separated list of allowed players"
        },
    "treat_whitelist_as_blacklist": {
        "type": "checkbox",
        "description": "Treat whitelist as blacklist instead",
        "default": false
    },
    "head5":{
        "type": "header",
        "description": ""
    },
    "debug_mode": {
        "type": "checkbox",
        "description": "Debug Mode",
        "default": false,
        "tooltip": "Log debug outputs in cinnamon log"
    }
}
